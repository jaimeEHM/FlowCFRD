# Workflow — copia a .env y ejecuta: php artisan key:generate
# Colas: database por defecto; para Redis descomenta QUEUE_CONNECTION=redis y CACHE_STORE=redis.
# Correo: log en local; para envío real usa MAIL_MAILER=smtp (o proveedor) y completa MAIL_*.

APP_NAME=Workflow
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://flowcfrdlocal.cfrd.cl

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=flowcfrd_db
DB_USERNAME=cfrd_admin
DB_PASSWORD="cf753rd/"

# API Sanctum: cookies SPA opcionales (ver config/sanctum.php). Tokens Bearer vía POST /api/v1/auth/token.
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000,::1

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Broadcasting: `null` desactiva WebSockets y la UI no suscribe Echo.
# Tiempo real (Laravel Reverb): terminal aparte → `php artisan reverb:start` (puerto 8080 por defecto).
BROADCAST_CONNECTION=reverb

REVERB_APP_ID=workflow
REVERB_APP_KEY=workflow-key
REVERB_APP_SECRET=workflow-secret
REVERB_HOST=flowcfrd-reverb
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=flowcfrdlocal.cfrd.cl
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https
VITE_REVERB_ENABLED=true

FILESYSTEM_DISK=local

QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# Google OAuth (dominio institucional, p. ej. @udec.cl). Consola: credenciales OAuth 2.0, URI autorizado:
# {APP_URL}/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Opcional; por defecto {APP_URL}/auth/google/callback
GOOGLE_REDIRECT_URI=

# Dominio mostrado en login / textos (sin @); suele ser cfrd.cl
WORKFLOW_CFRD_DOMAIN=cfrd.cl
# Dominios aceptados en OAuth Google, separados por coma (cfrd.cl y udec.cl en CFRD/UdeC)
WORKFLOW_CFRD_DOMAINS=cfrd.cl,udec.cl
# Cuenta(s) de desarrollo para login web por contraseña (separadas por coma).
# Requiere usuario sembrado: php artisan db:seed (CfrdDevUserSeeder). Comprobar: php artisan workflow:verify-dev-account
WORKFLOW_DEV_PASSWORD_EMAIL=admin@cfrd.cl
WORKFLOW_DEV_PASSWORD_EMAILS=admin@cfrd.cl,patricio@cfrd.cl
WORKFLOW_TRANSVERSAL_GROUP_ENABLED=false
WORKFLOW_TRANSVERSAL_GROUP_NAME="Línea transversal"

# LRS / xAPI (opcional; ver pantalla Sistema → LRS)
WORKFLOW_LRS_ENABLED=false
WORKFLOW_LRS_ENDPOINT=
WORKFLOW_LRS_KEY=

GOOGLE_ALLOWED_DOMAIN=