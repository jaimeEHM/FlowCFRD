# Workflow — copia a .env y ejecuta: php artisan key:generate
# Colas: database por defecto; para Redis descomenta QUEUE_CONNECTION=redis y CACHE_STORE=redis.
# Correo: log en local; para envío real usa MAIL_MAILER=smtp (o proveedor) y completa MAIL_*.

APP_NAME=Workflow
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=workflow
# Homebrew (macOS): suele ser tu usuario de sistema; comprobar con: psql -d postgres -tAc "SELECT current_user;"
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

QUEUE_CONNECTION=database
# QUEUE_CONNECTION=redis

CACHE_STORE=database
# CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# Google OAuth (dominio institucional, p. ej. @udec.cl). Consola: credenciales OAuth 2.0, URI autorizado:
# {APP_URL}/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Opcional; por defecto {APP_URL}/auth/google/callback
GOOGLE_REDIRECT_URI=

# Dominio mostrado en login / textos (sin @); suele ser cfrd.cl
WORKFLOW_CFRD_DOMAIN=cfrd.cl
# Dominios aceptados en OAuth Google, separados por coma (cfrd.cl y udec.cl en CFRD/UdeC)
WORKFLOW_CFRD_DOMAINS=cfrd.cl,udec.cl
# Única cuenta desarrollo (email/contraseña); por defecto admin@cfrd.cl (sembrada en cfrd_equipo.json)
WORKFLOW_DEV_PASSWORD_EMAIL=admin@cfrd.cl

# LRS / xAPI (opcional; ver pantalla Sistema → LRS)
WORKFLOW_LRS_ENABLED=false
WORKFLOW_LRS_ENDPOINT=
WORKFLOW_LRS_KEY=
