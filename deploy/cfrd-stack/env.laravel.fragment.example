# Fragmento para fusionar en .env cuando uses deploy/cfrd-stack/docker-compose.yml
# con el stack Microservicios (Postgres, Redis, Traefik).

# Desarrollo local CFRD (Traefik): usar este host en /etc/hosts si aplica
APP_URL=https://flowcfrdlocal.cfrd.cl

# Red Docker del stack CFRD (si no es la por defecto)
# CFRD_STACK_NETWORK=microservicios_service_net

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=flowcfrd_db
DB_USERNAME=cfrd_admin
DB_PASSWORD="cf753rd/"

CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_CLIENT=phpredis
REDIS_USERNAME=
REDIS_PASSWORD=

BROADCAST_CONNECTION=reverb
REVERB_APP_ID=workflow
REVERB_APP_KEY=workflow-key
REVERB_APP_SECRET=workflow-secret
# Interno entre contenedores:
REVERB_HOST=flowcfrd-reverb
REVERB_PORT=8080
REVERB_SCHEME=http
# Cliente web (browser) via Traefik:
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=flowcfrdlocal.cfrd.cl
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https
VITE_REVERB_ENABLED=true

# Produccion con assets compilados en el contenedor
VITE_DEV_SERVER_URL=
